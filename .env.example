# YDNT - Required Environment Variables
# Copy this file to .env and fill in real values.
# .env is in .gitignore and will NEVER be committed.

# Gemini API Key (required)
GEMINI_API_KEY=

# YouTube Data API v3 Key (required for real API calls)
YOUTUBE_API_KEY=

# GitHub Personal Access Token (optional, for verify_github_user)
GITHUB_TOKEN=

# Google Cloud Project ID (optional, for deployment)
# GOOGLE_CLOUD_PROJECT=

# Mock mode: set to 1 to use cached responses (default: 0)
# USE_MOCK=1
